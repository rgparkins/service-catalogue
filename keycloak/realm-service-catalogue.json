{
  "realm": "service-catalogue",
  "enabled": true,
  "displayName": "Service Catalogue",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "tenant-user" },
      { "name": "tenant-admin" },
      { "name": "global-admin" }
    ]
  },
  "groups": [
    { "name": "tenant:TalentConsultingSandBox:admin" }
  ],
  "clients": [
    {
      "clientId": "service-catalogue-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ]
    },
    {
      "clientId": "service-catalogue-api",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Global",
      "lastName": "Admin",
      "email": "admin@example.com",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin", "global-admin"]
    }
  ]
}
